<domain name="name_length" not-null="false">
	<schema name="public"/>
	<role name="postgres"/>
	<type name="varchar" length="50"/>
	<constraint name="length" type="check">
		<expression> <![CDATA[length(btrim(VALUE)) >= 2]]> </expression>
	</constraint>
</domain>

