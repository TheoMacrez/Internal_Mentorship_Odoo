	</column>
	<column name="end_time" not-null="true">
		<type name="time" length="0"/>
	</column>
	<column name="employee_id" not-null="true">
		<type name="smallint" length="0"/>
	</column>
	<constraint name="pk_availability" type="pk-constr" table="public.availability">
		<columns names="id_availability" ref-type="src-columns"/>
	</constraint>
	<constraint name="chk_availability_time" type="ck-constr" table="public.availability">
			<expression> <![CDATA[start_time < end_time]]> </expression>
	</constraint>
</table>

<table name="request" layers="0" collapse-mode="2" max-obj-count="6" z-value="0">
	<schema name="public"/>
	<role name="postgres"/>
	<position x="940" y="280"/>
	<column name="id_request" not-null="true"
	 identity-type="ALWAYS">
		<type name="smallint" length="0"/>
	</column>
	<column name="start_level" not-null="true">
		<type name="smallint" length="0"/>
	</column>
	<column name="target_level" not-null="true">
		<type name="smallint" length="0"/>
	</column>
	<column name="employee_id" not-null="true">
		<type name="smallint" length="0"/>
	</column>
	<column name="skill_id" not-null="true">
		<type name="smallint" length="0"/>
	</column>
	<constraint name="pk_request" type="pk-constr" table="public.request">
		<columns names="id_request" ref-type="src-columns"/>
	</constraint>
	<constraint name="chk_request_level" type="ck-constr" table="public.request">
			<expression> <![CDATA[start_level BETWEEN 1 AND 5
    AND target_level BETWEEN 1 AND 5
    AND target_level > start_level]]> </expression>
	</constraint>
</table>

<table name="mentorship" layers="0" collapse-mode="2" max-obj-count="10" z-value="0">
	<schema name="public"/>
	<role name="postgres"/>
	<position x="700" y="680"/>
	<column name="id_mentorship" not-null="true"
	 identity-type="ALWAYS">
		<type name="smallint" length="0"/>
	</column>
	<column name="start_date" not-null="true">
		<type name="date" length="0"/>
	</column>
	<column name="end_date">
		<type name="date" length="0"/>
	</column>
	<column name="status" not-null="true">
		<type name="varchar" length="50"/>
	</column>
	<column name="score" not-null="true">
		<type name="smallint" length="0"/>
	</column>
	<column name="mentor_profile_id" not-null="true">
		<type name="smallint" length="0"/>
	</column>
	<column name="mentee_id" not-null="true">
		<type name="smallint" length="0"/>
	</column>
	<column name="request_id" not-null="true">
		<type name="smallint" length="0"/>
	</column>
	<column name="skill_id" not-null="true">
		<type name="smallint" length="0"/>
	</column>
	<constraint name="pk_mentorship" type="pk-constr" table="public.mentorship">
		<columns names="id_mentorship" ref-type="src-columns"/>
	</constraint>
	<constraint name="chk_mentorship_dates" type="ck-constr" table="public.mentorship">
			<expression> <![CDATA[end_date IS NULL OR end_date >= start_date]]> </expression>
	</constraint>
	<constraint name="uq_mentorship_request" type="uq-constr" table="public.mentorship">
		<columns names="request_id" ref-type="src-columns"/>
	</constraint>
</table>

